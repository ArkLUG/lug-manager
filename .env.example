# Server
LUG_PORT=8080
LUG_DB_PATH=./lug.db
LUG_TEMPLATES_DIR=./src/templates

# Discord Bot (for creating events/threads)
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord OAuth2 App (for user login)
DISCORD_CLIENT_ID=your_oauth2_client_id
DISCORD_CLIENT_SECRET=your_oauth2_client_secret
DISCORD_REDIRECT_URI=http://localhost:8080/auth/callback

# Bootstrap admin: set to your Discord user ID to auto-create an admin account on first login.
# Remove or leave blank after initial setup.
BOOTSTRAP_ADMIN_DISCORD_ID=
